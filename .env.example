# Oracle 접속 (.env로 복사 후 값 입력)
ORACLE_USER=dispatcher
ORACLE_PASSWORD=change_me

# 방법 A: DSN 직접 지정
# ORACLE_DSN=host:1521/SERVICE_NAME

# 방법 B: 호스트 조립 (HOST2 지정 시 페일오버)
ORACLE_HOST1=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
# ORACLE_HOST2=backup-host

# DB SELECT 시 FAC_ID 필수 (--fac-id 미지정 시 사용)
DEFAULT_FAC_ID=ICPRB

# pytest live DB 테스트 (scripts/test_db_step*.py 와 tests/test_db_live.py)
# ORACLE_LIVE_TEST=1
