# API 서버 포트 (uvicorn --port, Vite /api 프록시 대상)
API_PORT=7000

# Oracle 접속 (.env로 복사 후 값 입력)
ORACLE_USER=dispatcher
ORACLE_PASSWORD=change_me

# 방법 A: DSN 직접 지정
# ORACLE_DSN=host:1521/SERVICE_NAME

# 방법 B: 호스트 조립 (HOST2 지정 시 페일오버)
ORACLE_HOST1=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1
# ORACLE_HOST2=backup-host

# DB SELECT 시 facid·batchid 필수 (--facid/--batchid 미지정 시 사용)
DEFAULT_FACID=ICPRB
DEFAULT_BATCHID=B1

# RL 환경 패딩 크기 — 변경 시 재학습 필요 (.env 로 관리, git 충돌 방지)
MAX_TASKS=8
MAX_MODELS=5

# UI KPI/퍼센트 표시 소수 자릿수
UI_METRIC_DIGITS=1

# 전환 그룹 기본값 (런타임/학습 UI에서 덮어쓸 수 있음)
# CONV_GROUPS={"G1":["B1","B2","B3"]}

# pytest live DB 테스트 (scripts/test_db_step*.py 와 tests/test_db_live.py)
# ORACLE_LIVE_TEST=1
